{
  "compilerOptions": {
    /* Basic Options */
    "target": "es5",
    "module": "commonjs",
    "declaration": true,
    "outDir": "./dist",
    "strict": true,
    "baseUrl": "./",
    "typeRoots": ["./types/*"],
    "types": ["cypress"],
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "src/**/*"  /* Include only your source files for compilation */
  ],
  "exclude": [
    "./cypress",         /* Exclude the cypress folder */
    "./cypress.config.ts" /* Exclude the Cypress config file */
  ]
}
